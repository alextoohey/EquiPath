# EquiPath environment variables
# Copy this file to .env and fill in your values. Everything here is optional:
# the app runs without an API key, but AI explanations and the Q&A chat
# require ANTHROPIC_API_KEY.

# Anthropic API key (get one at https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=your-api-key-here

# Claude model for explanations and chat (fast + inexpensive default)
ANTHROPIC_MODEL=claude-haiku-4-5

# Optional: ElevenLabs API key for voice input/output in the chat assistant
# (https://elevenlabs.io/)
ELEVENLABS_API_KEY=your-api-key-here
